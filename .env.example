# ==============================================================================
# Audio Research Assistant - environment template
# Copy to ".env" and add your private values.
#
# Keep the real .env private. It is gitignored and must never be committed.
# ==============================================================================


# ==============================================================================
# 01. App Runtime
# ==============================================================================

DEBUG_MODE=false


# ==============================================================================
# 02. Auth
# ==============================================================================

# false = local single-user mode. true = require /login.
ENABLE_AUTH=false

# Required for stable login sessions when ENABLE_AUTH=true.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET_KEY=

# true = visitors may self-register at /login.
ENABLE_SIGNUP=false

# Empty = browser-session cookie. Example one week: 604800
SESSION_MAX_AGE=

# Optional custom auth DB path.
# AUTH_DB_PATH=data/auth.db

# Conversations (sessions/turns/facts) live in their own SQLite file, separate from the
# answer cache (data/memory.db). On first run, existing conversations are migrated over
# once (the old file is never deleted). Default: data/conversations.db
CONVERSATIONS_DB_PATH=data/conversations.db

# Forgot password: single-user self-hosted with no email server? Set this true to
# show the reset link on the page. For multi-user/production, keep it false and
# configure SMTP below so reset links are emailed instead.
AUTH_RESET_RETURN_LINK=false
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=Research Assistant <you@example.com>

# "Sign in with Google" (optional). Create an OAuth client at
# https://console.cloud.google.com/apis/credentials (Web app) and add the redirect URI
# http://localhost:8600/auth/google/callback  (+ your public URL for production).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# PUBLIC_BASE_URL=                      # e.g. https://research.example.com (pins reset/OAuth URLs)


# ==============================================================================
# 03. Database / Local PDF RAG
# ==============================================================================

ORACLE_USER=AUDIO_RAG
ORACLE_PASSWORD=change_me
ORACLE_DSN=localhost:1521/FREEPDB1

# false = web-only mode. true = also search indexed local PDFs in Oracle.
ENABLE_LOCAL_RAG=false

# Dense-vector backend for local PDFs:
# oracle    = exact Oracle VECTOR search (default, safest)
# turbovec  = compressed local accelerator; Oracle still stores text/metadata
VECTOR_BACKEND=oracle
TURBOVEC_ENABLED=false
TURBOVEC_AUTOBUILD=true
TURBOVEC_BUILD_IN_PIPELINE=false
TURBOVEC_INDEX_PATH=data/vector_cache/chunks.tvim
TURBOVEC_BIT_WIDTH=4
TURBOVEC_OVERFETCH=3
TURBOVEC_STRICT=false
TURBOVEC_BUILD_BATCH=4096


# ==============================================================================
# 04. Chat LLM
# ==============================================================================

# The Model dropdown offers: Gemini 2.5 Flash, Mistral Large, Mistral Codestral, GPT-5.5.
# Picking one rewrites the 3 ACTIVE lines below by model name.
OPENAI_API_KEY=                      # the active model's key (dropdown sets this)
OPENAI_MODEL=gemini-2.5-flash
# OPENAI_BASE_URL=                   # dropdown sets this per provider
#
# Paste a key for each provider you want to use:
GEMINI_API_KEY=                      # Gemini 2.5 Flash (free)     https://aistudio.google.com/apikey
MISTRAL_API_KEY=                     # Mistral (Large, Codestral)  https://console.mistral.ai
OPENAI_CLOUD_KEY=                    # GPT-5.5 (paid)              your OpenAI key


# ==============================================================================
# 05. Embeddings / Reranking
# ==============================================================================

# Embeddings are a LOCAL sentence-transformers model on your GPU/CPU — free, no quota, no network, no
# API key. (Google/Gemini embeddings were removed; EMBEDDING_PROVIDER is ignored and always "local".)
# NOTE: changing the model changes the vector DIMENSION, so you must re-embed the whole corpus:
#       run `python pipeline.py --reembed` after switching.
EMBEDDING_PROVIDER=local
# Default: BAAI/bge-large-en-v1.5 (1024-d) — free, top-tier retrieval, fits a 6 GB GPU in fp16.
# Multilingual alternative: EMBEDDING_MODEL=BAAI/bge-m3 (also 1024-d, instruction-free).
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DIM=1024
# bge query INSTRUCTION (prepended to QUERIES only, never to documents — the asymmetric encoding bge
# wants). Auto-empty for bge-m3. Leave as default unless you know you want a different instruction.
BGE_QUERY_INSTRUCTION=Represent this sentence for searching relevant passages:
# Local embedding GPU controls: fp16 halves VRAM (~2x faster) so bge-large fits the 6 GB 3050 alongside
# the reranker; the encode batch size is bounded to stay in budget. On a CUDA out-of-memory the model
# falls back to CPU automatically (logged) — it never OOM-crashes. Set EMBED_FP16=false to force fp32.
EMBED_FP16=true
EMBED_ST_BATCH=16

RERANKER_MODEL=BAAI/bge-reranker-v2-m3


# ==============================================================================
# 06. External Search
# ==============================================================================

ENABLE_WEB_SEARCH=true

# duckduckgo works without a key. tavily/brave/serpapi can be better for web.
WEB_SEARCH_PROVIDER=duckduckgo
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
SERPAPI_API_KEY=

# Optional: raises GitHub limits and enables code search.
GITHUB_TOKEN=
GITHUB_REPO_SORT=stars             # famous/popular repos first; "updated" = pure recency
# NOTE: external fetching has no SSRF guard (removed) — it can reach any address.


# ==============================================================================
# 07. Answer Quality / Agentic Verification
# ==============================================================================

# RUN MODES (fast/deep): the per-request mode (chosen with the "Deep research" toggle in the
# UI, or the `mode` field on /api/chat) OVERRIDES the knobs below for that request via
# backend/answering/research_modes.py:
#   fast (default) -> subqueries 0, ext_top_k 8, web 4, arxiv 0, verify rounds 1, auto-review off,
#                     evidence 14000, answer 3000, gather timeout 12s  (local-first + quick)
#   deep           -> subqueries 3, ext_top_k 20, web 8, arxiv 3, verify rounds 3, auto-review on,
#                     evidence 28000, answer 8000, gather timeout 30s  (full research sweep)
# AGENTIC_MIN_VERIFY_SCORE (the accuracy bar) is the SAME in both modes — speed never lowers it.
# The values below are the fallback defaults when no mode is applied (e.g. CLI/eval entry points).
EVIDENCE_CHARS_PER_SOURCE=3500
SOURCE_MIN_SCORE=0.30
SOURCE_MIN=3
SOURCE_MAX=12
EXTERNAL_TOP_K=20
ANSWER_MAX_TOKENS=8000

# --- Corrective RAG (CRAG): grade the local PDF evidence, then act on the grade ---
# After local retrieval the reranker scores are graded: STRONG -> answer from the PDFs alone
# (skip external search); PARTIAL -> keep the PDFs AND search the web/papers/GitHub to fill gaps;
# NONE -> drop local and go fully external. Code-intent queries whose algorithm is found in the
# PDFs are implemented from the paper (cited), supplementing with GitHub refs only when thin.
# Set CRAG_ENABLED=false to fall back to the original always-concurrent local+external sweep.
CRAG_ENABLED=true
CRAG_STRONG_MIN=0.55       # a chunk at/above this rerank score is strong evidence
CRAG_PARTIAL_MIN=0.30      # below this a chunk is not relevant enough to count
CRAG_STRONG_COUNT=2        # how many strong chunks make the grade STRONG
CRAG_PAPER_MIN_CHUNKS=2    # fewer relevant chunks than this -> paper is thin, add GitHub refs
# Latency options (off by default — they change timing, not results):
#   CRAG_SPECULATIVE_EXTERNAL: start the web search in parallel with local retrieval so PARTIAL/NONE
#     don't pay local-then-external sequentially. A STRONG grade discards the prefetch, so this
#     trades some web-search spend for latency — opt in only if quota isn't a concern.
#   CRAG_GRADE_CACHE: reuse a recent (evidence, grade) for the same question within a session (helps
#     regenerate, which bypasses the answer cache). TTL-bounded by CRAG_GRADE_CACHE_TTL (seconds).
CRAG_SPECULATIVE_EXTERNAL=false
CRAG_GRADE_CACHE=false
CRAG_GRADE_CACHE_TTL=120

ENABLE_AGENTIC_ANSWER_LOOP=true
AGENTIC_MAX_VERIFY_ROUNDS=3
AGENTIC_MIN_VERIFY_SCORE=80
AGENTIC_EXTRA_SEARCH_K=8
AGENTIC_SIMULATE_CODE=true
AGENTIC_SIMULATION_TIMEOUT=30
AGENTIC_VERIFY_MAX_TOKENS=1200

# Reuse saved answers for the same/very-similar question to avoid repeat search +
# LLM cost. Matching is lexical (near-exact) OR semantic (embeddings), and a guard
# blocks swaps/identifier changes ("A vs B" != "B vs A", "A100" != "H100") so a
# different question is never served a wrong cached answer. Freshness-sensitive
# questions ("latest", "2026", "state of the art", ...) always re-search. The cache
# is auto-cleared when you ingest/delete local PDFs.
ENABLE_ANSWER_CACHE=true
ANSWER_CACHE_MIN_SIMILARITY=0.97      # lexical bar (keep high; >=0.92 enforced)
ENABLE_ANSWER_CACHE_SEMANTIC=true    # embedding match for paraphrases (uses the local bge embedder)
ANSWER_CACHE_MIN_SEMANTIC=0.88       # cosine bar for a semantic match
ANSWER_CACHE_MAX_AGE_DAYS=30
ANSWER_CACHE_CANDIDATE_LIMIT=200
ANSWER_CACHE_ALLOW_FRESHNESS_QUERIES=false
# Automatically peer-review the final answer/code (the "Review" step, run for you):
# critique it, improve once if weak, show the verdict. One extra LLM call — set false
# to skip on slow local models.
AUTO_REVIEW=true

# Compact conversation memory (Mem0-style layering): instead of sending raw chat history every
# turn, the LLM context = last N turns verbatim + a rolling SUMMARY of older turns + the FACTS
# relevant to the current question, capped at a token budget. This shapes ONLY what is sent to
# the model — the full conversation is still stored and shown to the user. Falls back to
# recent-only if summarization fails, so chat never breaks.
COMPACT_MEMORY=true
MEMORY_RECENT_TURNS=4          # most recent turns kept verbatim
MEMORY_MAX_TOKENS=3000         # cap on the assembled memory context (facts + summary + recent)
MEMORY_SUMMARY_STALE=2         # re-summarize once this many older turns have accumulated (1 LLM call)
MEMORY_MAX_FACTS=6             # max relevant facts injected per turn
# MEMORY_SUMMARY_MAX_TOKENS=400  # token budget for the summary LLM call
# MEMORY_SUMMARY_TIMEOUT=8       # seconds before falling back to recent-only


# ==============================================================================
# 08. External Search Limits
# ==============================================================================

EXTERNAL_HTTP_TIMEOUT=12
EXTERNAL_MAX_BYTES=3000000
EXTERNAL_MAX_RETRIES=2
EXTERNAL_CACHE_TTL=3600
EXTERNAL_MAX_PDFS=3
WEB_MAX_RESULTS=8

ARXIV_MAX_RESULTS=6
ARXIV_READ_PDF_COUNT=3
SEMANTIC_SCHOLAR_MAX=6
WIKIPEDIA_MAX=3
PATENT_MAX_RESULTS=4

ONLINE_PDF_MAX_PAGES=30
ONLINE_PDF_MAX_CHUNKS=12
ONLINE_PDF_CHUNK_CHARS=1600

GITHUB_MAX_REPOS=5
GITHUB_MAX_FILES=3
GITHUB_MAX_FILE_BYTES=60000
GITHUB_EXCERPT_LINES=120


# ==============================================================================
# 09. Autonomous Code Agent
# ==============================================================================

# AGENT_MAX_ATTEMPTS: the agent keeps iterating — feeding each round's GENUINE failing checks back
# and regenerating only what's needed — until the solution is FULLY verified, this cap is reached,
# or progress STALLS. Default 10. (Legacy AGENT_MAX_ITERS below is the fallback if this is unset.)
AGENT_MAX_ATTEMPTS=10
# AGENT_STALL_LIMIT: stop early after this many CONSECUTIVE rounds that don't reduce the number of
# genuine failing checks — return the best effort, labelled honestly, instead of burning the cap.
AGENT_STALL_LIMIT=3
AGENT_MAX_ITERS=4
AGENT_GEN_MAX_TOKENS=5000
AGENT_REFLECT_MAX_TOKENS=2000

# Parallel best-of-N: generate this many candidate solutions CONCURRENTLY each round and keep the
# best GENUINE passer (verified > more visible passes > ran; cheating/off-topic never win).
# Clamped 1-8; 1 = serial. Candidates are diversified by temperature + a "different approach" hint.
AGENT_PARALLEL_N=4
# Hard cap on how many sandbox CONTAINERS run AT ONCE across all parallel candidates (the rest
# queue). Bounds Docker load; does NOT weaken any container's own limits (network/cpu/mem/pids/
# timeout/non-root/--rm are unchanged).
AGENT_MAX_CONCURRENT_SANDBOXES=4

# Semantic code-intent routing: an LLM classifies whether a message is a code/simulate/benchmark/
# model/compute task in ANY domain or phrasing (and which verification type it needs), unioned with
# the regex fast-path for high recall. Cached + timeout-bounded; falls back to pure regex when the
# LLM is unavailable. false = regex only (instant, no routing LLM call).
CODE_INTENT_SEMANTIC=true
CODE_INTENT_TIMEOUT=3.0

# Dynamic sandbox dependencies (domain-independent): parse the generated code's imports, build
# (and cache by hash) a sandbox image with exactly those pip packages on top of the base
# scientific image, then run it. Network is allowed ONLY during the image build; every code RUN
# stays --network none + the CPU/mem/PID/timeout/non-root caps. Falls back to the base image if a
# package can't be resolved/built (the ImportError then drives the agent to rewrite). Off = base
# image only (no extra installs).
AGENT_DYNAMIC_DEPS=true

# Optional stronger model for escalation after repeated test failures / test-gaming catches. It is
# a FALLBACK, never an override: it only LEADS escalation when no model was explicitly selected
# (AGENT_MODEL unset and the chat model left at its default). When you HAVE picked a model, the
# agent keeps your choice and only uses other configured models to recover from a 429/timeout. Any
# model id the chat router knows; unset = never escalate (still falls back to available models on
# rate limits).
AGENT_MODEL_STRONG=

# Anti-reward-hacking hardening (a solution that merely passes the visible tests is NOT trusted).
# AGENT_HIDDEN_TESTS : at final acceptance, also run HELD-OUT hidden tests + invariant-property
#                      checks on fresh RANDOM inputs (never shown to the model). Passing visible
#                      but failing these = special-casing the examples -> reject + regenerate.
# AGENT_VERIFY_SEEDS : how many independent random seeds the held-out suite must ALL pass on.
# AGENT_ANTICHEAT_SCAN: static AST scan that flags hardcoded outputs / test-aware code / fake
#                      functions / harness tampering before a pass is trusted -> reject + regenerate.
AGENT_HIDDEN_TESTS=true
AGENT_VERIFY_SEEDS=3
AGENT_ANTICHEAT_SCAN=true
# AGENT_REFERENCE_TESTS: derive each test's EXPECTED value by RUNNING a reference oracle in the
# sandbox (then assert the candidate reproduces it), instead of letting the test-LLM guess literal
# outputs — eliminates false failures from imagined values / library mismatches on ANY task.
# (Simulation tasks still use property/invariant tests.) Off falls back to property/legacy tests.
AGENT_REFERENCE_TESTS=true
# AGENT_DELIVERY_GATES: for a task that asks to print/show/return a result, enforce two more gates
# before labelling a solution "verified": the EXECUTION gate (it must actually run and produce real
# stdout) and the COMPLETENESS gate (every requested deliverable must appear in that stdout). A
# solution that drops a requested output or produces nothing -> partially verified -> regenerate.
AGENT_DELIVERY_GATES=true
# AGENT_DEFINITION_GATE: held out alongside the hidden tests, ONE check per requested output asserts
# the REPORTED value is the exact thing asked for — right quantity, point/time, aggregation, units —
# computed independently of the candidate AND its reference oracle (which could share a wrong
# definition). Catches "right logic, wrong reported answer" (mean for median, post-first-step for
# initial, degrees for radians, label-vs-logic). Runs even if AGENT_HIDDEN_TESTS is off.
AGENT_DEFINITION_GATE=true
# AGENT_TEST_VALIDATION: before a generated test is allowed to FAIL a candidate, run it against the
# known-correct reference oracle; any test the oracle ITSELF fails is invalid (guessed expected,
# tolerance too tight for the method, or wrong quantity) and is QUARANTINED — excluded from the
# pass/total so a flawed test never falsely fails correct code, while every oracle-passing test still
# catches genuinely wrong code. Needs AGENT_REFERENCE_TESTS. Off trusts every generated test.
AGENT_TEST_VALIDATION=true

# Leave AGENT_DOCKER_IMAGE unset to use the built-in scientific sandbox image
# (numpy/scipy/pandas/matplotlib/sklearn/sympy/soundfile preinstalled), which is
# built automatically on first run. Only set this to pin your own image.
# AGENT_DOCKER_IMAGE=
AGENT_RUN_TIMEOUT=30
AGENT_MEM_LIMIT=512m
AGENT_CPUS=1.0
AGENT_PIDS_LIMIT=128
# AGENT_BUILD_TIMEOUT=1200   # seconds allowed for the one-time sandbox image build

AGENT_BRIEF_MAX_CHARS=3000
AGENT_LOG_MAX_CHARS=2000
AGENT_LOG_KEEP_LAST=12

AGENT_AUDIT_LOG=data/logs/agent_audit.jsonl
AGENT_BLOCK_PATTERNS=
AGENT_PRERUN_HOOK=



# ==============================================================================
# 10. Device / Local Model Runtime
# ==============================================================================

# auto | cuda | cpu | cuda:0
# "auto" uses the GPU when CUDA is available (e.g. an RTX 3050). The cross-encoder reranker
# and the local embedding model both run on the GPU; the chat LLM is in the cloud. The models
# are pre-warmed at app startup so the first query isn't slow.
DEVICE=auto
EMBEDDING_DEVICE=auto
RERANKER_DEVICE=auto

# fp16 (half precision) for the reranker on CUDA: ~2x faster + half the VRAM (fits 6 GB easily).
# Safe — it only affects relative reranking order. Set false to force fp32.
RERANKER_FP16=true

# Cross-encoder reranker for LOCAL PDF retrieval. Set false on a low-memory host where the torch
# model can't load (OSError 1455 "paging file too small") — local retrieval then uses a cheap
# lexical scorer instead of failing. The cross-encoder also auto-falls-back to lexical if it
# raises at load time, so this is mainly an explicit opt-out. Lexical scores stay on the same
# 0..1 scale as the CRAG grader thresholds.
LOCAL_RERANK_CROSS_ENCODER=true


# ==============================================================================
# 11. PDF Ingestion / Chunking
# ==============================================================================

# OCR is OFF by default: born-digital PDFs parse via text extraction (no OCR), which is fast and
# never touches the GPU. Set true to enable OCR — it then runs ONLY on text-poor (scanned) pages,
# always on the CPU. (Docling's own RapidOCR is always disabled because it self-selects the GPU.)
ENABLE_OCR=false
# Device for Docling LAYOUT parsing. Default (cpu / unset): ingestion hides CUDA from the parse
# process, so Docling NEVER attempts the GPU (its CPU flag isn't always honoured, and a GPU attempt
# OOMs std::bad_alloc on small cards). The reranker/embedder still use the GPU at query time. Set
# cuda ONLY to opt back into GPU layout. OCR always runs on the CPU regardless of this.
DOCLING_DEVICE=cpu
# Docling is a HEAVY ML parser and OPT-IN (default OFF). On a CPU-only host it is by far the slowest
# ingest stage (~60-90 s/paper of native ML inference, and it can crawl for many minutes on large
# papers or even OOM/segfault the process). Its only real payoff is clean TABLE row/column structure,
# and it often extracts nothing here — the fast PyMuPDF text path already indexes every page (metric
# numbers included), so retrieval is largely unaffected. Turn it on (ENABLE_DOCLING=true) ONLY when you
# specifically need clean tables; even then it skips low-memory hosts and (below) non-table papers.
ENABLE_DOCLING=false
DOCLING_MIN_FREE_MB=1500
# Fast clean tables WITHOUT Docling: extract tables as proper |grid| markdown via PyMuPDF's built-in
# find_tables() (heuristic, NO ML/GPU, ~1-4 s/paper). Runs on every paper when Docling didn't already
# supply tables, so tables index as real grids (not flattened text). Default ON; set false to skip.
ENABLE_PYMUPDF_TABLES=true
# Conditional Docling (default ON): Docling's payoff is clean TABLE row/column structure, so it runs
# ONLY on table-rich papers and the rest use the fast PyMuPDF text — a big speed win with no quality
# loss where there are no tables. A paper's "table richness" = distinct 'Table N' references (x3) +
# pipe rows; Docling runs when that score >= DOCLING_TABLE_TRIGGER. Raise the trigger to run Docling on
# fewer papers (faster); lower it to run on more (more thorough). DOCLING_CONDITIONAL=false restores
# always-run (memory permitting). ENABLE_DOCLING=false still disables Docling entirely.
DOCLING_CONDITIONAL=true
DOCLING_TABLE_TRIGGER=6
CHUNK_MAX_CHARS=1800
CHUNK_OVERLAP_SENTENCES=2
MIN_SENTENCE_CHARS=10
MIN_CHUNK_CHARS=150
EMBED_DB_BATCH=16
# Semantic chunking (default OFF): split prose at TOPIC shifts (meaning) instead of a fixed char
# budget, via Chonkie's SemanticChunker + a Model2Vec static embedder (CPU-only, ~30 MB, NO GPU). Our
# tables / figure captions / algorithm blocks are still extracted as their own chunks either way; this
# only changes how the prose BODY is split. Falls back to the legacy sentence-packer if unavailable.
SEMANTIC_CHUNKER=false
SEMANTIC_CHUNKER_MODEL=minishlab/potion-base-8M
SEMANTIC_CHUNKER_THRESHOLD=0.75   # 0-1; higher = split more eagerly at topic shifts
SEMANTIC_CHUNK_SIZE=512           # max tokens/chunk (aligns with bge-large's embedding window)
# Figure understanding (default OFF): a text-only RAG can't read charts/figures. When on, each figure is
# cropped to its region and described; the description is indexed as a searchable 'figure' chunk.
# Backend: 'local' (default) = a DEDICATED self-hosted vision model (FIGURE_VLM_MODEL, default
# Qwen2-VL-2B — native transformers, ~4.8GB VRAM fits a 6GB card, FREE, no API/quota, deployable).
# Run figure description as a batch job when the GPU is free; the describe-once cache makes it one-time.
# 'llm' = a cloud multimodal model (FIGURE_MODEL) instead — convenient but per-call cost/quota.
ENABLE_FIGURE_UNDERSTANDING=false
FIGURE_BACKEND=local
FIGURE_VLM_MODEL=Qwen/Qwen2-VL-2B-Instruct
FIGURE_VLM_MAX_PIXELS=705600      # cap vision tokens (=900*28*28) to bound VRAM on a 6GB card
FIGURE_VLM_MAX_TOKENS=220
FIGURE_MODEL=gemini-2.5-flash     # only used when FIGURE_BACKEND=llm
FIGURE_MAX_PER_PAPER=12
FIGURE_RENDER_MAX_PX=1100         # longest side of the rendered figure image
FIGURE_DESCRIBE_TIMEOUT=45        # (llm backend) hard per-figure timeout (s)
FIGURE_CACHE=true                 # describe-once: cache by image hash so re-indexes are FREE
FIGURE_DESCRIBE_RETRIES=4         # (llm backend) retries on a 429 rate-limit before skipping

# Optional vector index during migration.
CREATE_VECTOR_INDEX=false

# Contextual Retrieval (Anthropic-style): at ingestion, the LLM writes a 50-100 token sentence
# situating each chunk in its document, prepended to the chunk for embedding (better recall). It is
# OPT-IN / DEFAULT OFF because it costs one LLM call per ~8 chunks (slow + rate-limit-prone on free
# tiers). The instant "contextual chunk header" (paper title + section, added at embed time, NO LLM)
# already situates every chunk for free — so the fast default is OFF. Turn this on for the extra few %
# of recall if you can afford the LLM calls. Cached on disk so re-runs are cheap.
CONTEXTUAL_CHUNKS=false
CONTEXTUAL_DOC_CHARS=12000        # how much of the document the LLM sees as context (cost control)
CONTEXTUAL_MAX_TOKENS=1024        # generous: reasoning models (Gemini 2.5) "think" before the answer
CONTEXTUAL_RETRIES=3             # retries with backoff on transient rate-limit/quota/5xx errors
# PRIMARY contextualization model. Ingestion fires a BURST of concurrent calls (one per chunk), so this
# should be a model that TOLERATES concurrency. Gemini handles it; a fast-but-rate-limited model like
# Mistral 429s under the burst (blanking the contexts) and is better as a fallback below. NOT tied to
# your chat model — contextualization just needs a cheap one-sentence writer.
CONTEXTUAL_MODEL=gemini-2.5-flash
# Cross-vendor fallbacks tried (in order) if the primary is rate-limited/unavailable, then your chat
# default last — so one provider's 429 can't blank a whole paper's contexts.
CONTEXTUAL_FALLBACK_MODELS=mistral-large-latest
# How many situating-sentence calls run at once (cache-miss chunks). 6 is fine for Gemini; lower it if
# you see sustained 429s, raise it if your provider's rate limit is generous.
CONTEXTUAL_CONCURRENCY=6
# Chunks situated per LLM call. ~8 turns a 75-chunk paper from 75 calls into ~10 — much faster and far
# gentler on rate limits, with identical per-chunk contexts (a malformed batch reply safely falls back
# to one call per chunk). Set 1 for the old one-call-per-chunk behavior.
CONTEXTUAL_BATCH_SIZE=8


# ==============================================================================
# 12. Local Retrieval Advanced Knobs
# ==============================================================================

RRF_K=60
MMR_LAMBDA=0.7
ENABLE_HYDE=true


# ==============================================================================
# 13. Public Tunnel / Sharing
# ==============================================================================

# Used only if your run.py share workflow is enabled.
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_TUNNEL_HOSTNAME=


# ==============================================================================
# 14. Observability & Evaluation  (both OFF by default)
# ==============================================================================

# LLM tracing with Langfuse (self-hosted). Tracing activates ONLY when ENABLED=true
# AND all three keys are set; otherwise the app behaves byte-identically with zero
# overhead. See docs/OBSERVABILITY.md to self-host Langfuse and get your keys.
LANGFUSE_ENABLED=false
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=your_key_here
LANGFUSE_SECRET_KEY=your_key_here

# DeepEval LLM-quality gates (tests/test_llm_quality.py). When false (default), those
# tests skip cleanly and the offline suite is unaffected. Needs a judge-model key when
# enabled — see the test file's docstring.
DEEPEVAL_ENABLED=false
