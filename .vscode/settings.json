{
  "python.defaultInterpreterPath": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
  "python.terminal.activateEnvironment": true,
  "python.envFile": "${workspaceFolder}/.env",
  "python.analysis.extraPaths": [
    "${workspaceFolder}"
  ],
  "python.analysis.typeCheckingMode": "basic",
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    ".venv": true,
    ".pytest_cache": true,
    ".ruff_cache": true,
    ".mypy_cache": true,
    ".deepeval": true,
    ".deepeval_telemetry.txt": true,
    ".deepeval-cache.json": true,
    "**/*.egg-info": true,
    "**/*.db-wal": true,
    "**/*.db-shm": true,
    "**/*.db-journal": true
  },
  "files.watcherExclude": {
    "**/.venv/**": true,
    "**/data/**": true,
    "**/backups/**": true
  },
  "search.exclude": {
    "**/.venv": true,
    "**/data/papers": true,
    "**/data/extracted": true
  },
  "editor.formatOnSave": false,
  "[python]": {
    "editor.rulers": [100]
  }
}
